{
  "expo": {
    "plugins": [
      [
        "@react-native-tvos/config-tv",
        {
          "androidTVBanner": "./assets/tv_icons/icon-400x240.png",
          "appleTVImages": {
            "icon": "./assets/tv_icons/icon-1280x768.png",
            "iconSmall": "./assets/tv_icons/icon-400x240.png",
            "iconSmall2x": "./assets/tv_icons/icon-800x480.png",
            "topShelf": "./assets/tv_icons/icon-1920x720.png",
            "topShelf2x": "./assets/tv_icons/icon-3840x1440.png",
            "topShelfWide": "./assets/tv_icons/icon-2320x720.png",
            "topShelfWide2x": "./assets/tv_icons/icon-4640x1440.png"
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "newArchEnabled": false
          },
          "android": {
            "newArchEnabled": false
          }
        }
      ],
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "name": "Set Dances",
    "slug": "set-dances",
    "version": "2.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "scheme": "set-dances",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#3099b8"
    },
    "android": {
      "userInterfaceStyle": "automatic",
      "package": "com.douglowder.setdances"
    },
    "ios": {
      "userInterfaceStyle": "automatic",
      "supportsTablet": true,
      "entitlements": {
        "aps-environment": "development"
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          }
        ]
      },
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ],
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.douglowder.Set-Dances"
    },
    "extra": {
      "updates": {
        "assetPatternsToBeBundled": [
          "assets/images/**/*.png",
          "assets/tv_icons/**/*.png"
        ]
      },
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "7c4c3b9b-bbb0-443d-a98e-6458a27e6363"
      }
    },
    "owner": "douglowderexpo",
    "updates": {
      "url": "https://u.expo.dev/7c4c3b9b-bbb0-443d-a98e-6458a27e6363"
    }
  }
}
