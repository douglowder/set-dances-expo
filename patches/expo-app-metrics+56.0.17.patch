+   `id < NULL` comparison deletes nothing.
+   */
+  @AppMetricsActor
+  private func trimTable(_ table: String, keeping maxRows: Int) throws {
+    // `table` is a literal we control (`metrics` / `logs`); SQLite has no placeholder for identifiers.
+    let statement = try database.prepare("""
+      DELETE FROM \(table)
+      WHERE id < (SELECT id FROM \(table) ORDER BY id DESC LIMIT 1 OFFSET ?1)
+      """)
+    try statement.bindAll([maxRows])
