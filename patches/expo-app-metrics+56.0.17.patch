+        domainLookupEnd: nil,
+        connectStart: nil,
+        connectEnd: nil,
+        secureConnectionStart: nil,
+        secureConnectionEnd: nil,
+        requestStart: nil,
+        requestEnd: nil,
+        responseStart: nil,
+        responseEnd: nil,
