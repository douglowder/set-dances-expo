+
+    val snapshot = buildSnapshot(
+      id = observationId,
+      originalRequest = originalRequest,
+      response = response,
+      phases = phases,
+      fallbackStart = startedAt,
+      fallbackEnd = endDate,
+      totalDuration = totalDuration,
+      error = error
