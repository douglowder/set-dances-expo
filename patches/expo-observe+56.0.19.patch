+});
+
+jest.mock('../router', () => ({
+  __esModule: true,
+  isRouterInstalled: true,
+  optionalRouter: {
+    useRoute: jest.fn(),
+    useNavigation: jest.fn(),
+    useCurrentRouteInfo: jest.fn(),
+    unstable_navigationEvents: {
