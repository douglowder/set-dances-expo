+  events.emit<Partial<PagePreloadedEvent>>('pagePreloaded', {
+    type: 'pagePreloaded',
+    screenId,
+    pathname: `/${screenId}`,
+    params: {},
+    segments: [screenId],
+    ...overrides,
+  });
+}
+
+function flushAsync() {
+  return new Promise((resolve) => setImmediate(resolve));
