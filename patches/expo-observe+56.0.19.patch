@@ -4,13 +4,29 @@ import ExpoModulesCore
 import ExpoAppMetrics
 
 public class ObserveAppDelegateSubscriber: ExpoAppDelegateSubscriber {
+  public func application(
+    _ application: UIApplication,
+    didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?
+  ) -> Bool {
+    // Long-running tvOS apps may rarely resign active, so the resign-active/terminate flushes below
+    // aren't enough — start a periodic dispatch so in-session metrics (navigation, etc.) are sent.
+    // Implementation is platform-agnostic; only this call is gated.
+    #if os(tvOS)
+    observeLogger.info("[EAS Observe] didFinishLaunching — starting periodic dispatch (tvOS)")
+    ObservabilityManager.startPeriodicDispatch()
+    #endif
+    return true
+  }
+
   public func applicationWillResignActive(_ application: UIApplication) {
+    observeLogger.info("[EAS Observe] applicationWillResignActive — triggering dispatch")
     AppMetricsActor.isolated {
       await ObservabilityManager.dispatch()
     }
   }
 
   public func applicationWillTerminate(_ application: UIApplication) {
+    observeLogger.info("[EAS Observe] applicationWillTerminate — triggering dispatch")
     AppMetricsActor.isolated {
       await ObservabilityManager.dispatch()
     }
