 namespace facebook::react {
@@ -431,6 +432,34 @@ void ReactInstance::initializeRuntime(
 
     defineReactInstanceFlags(runtime, options);
 
+    // patch-package: the bridgeless runtime does not install
+    // globalEvalWithSourceUrl (only the legacy JSIExecutor does), so Metro Fast
+    // Refresh falls back to eval(), which Hermes cannot parse for wrapped
+    // __d(...) modules. Mirror the JSIExecutor binding here.
+    runtime.global().setProperty(
+        runtime,
+        "globalEvalWithSourceUrl",
+        jsi::Function::createFromHostFunction(
+            runtime,
+            jsi::PropNameID::forAscii(runtime, "globalEvalWithSourceUrl"),
+            1,
+            [](jsi::Runtime& rt,
+               const jsi::Value& /*thisVal*/,
+               const jsi::Value* args,
+               size_t count) -> jsi::Value {
+              if (count != 1 && count != 2) {
+                throw std::invalid_argument(
+                    "globalEvalWithSourceUrl arg count must be 1 or 2");
+              }
+              auto code = args[0].asString(rt).utf8(rt);
+              std::string url;
+              if (count > 1 && args[1].isString()) {
+                url = args[1].asString(rt).utf8(rt);
+              }
+              return rt.evaluateJavaScript(
+                  std::make_unique<jsi::StringBuffer>(std::move(code)), url);
+            }));
+
     defineReadOnlyGlobal(
